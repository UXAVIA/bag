<?xml version="1.0" encoding="utf-8"?>
<!--
  Large widget (4×3+): native sparkline as full-bleed background,
  price / net-worth text overlaid on a built-in dark scrim.
  NativeChartRenderer draws the bitmap; no Flutter engine needed.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <!-- Full-bleed sparkline background rendered by NativeChartRenderer.
         fitXY is intentional: this is a decorative background, not a chart
         with text — aspect-ratio distortion is fine and ensures full coverage. -->
    <ImageView
        android:id="@+id/widget_chart_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY" />

    <!-- Text overlay — transparent background, same padding as medium widget.
         Content sits in the top portion which is covered by the renderer's scrim. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Price row: BTC label · price · change% · settings gear -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_btc_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BTC"
                android:textSize="9sp"
                android:textColor="#F7931A"
                android:textStyle="bold"
                android:layout_marginEnd="5dp" />

            <TextView
                android:id="@+id/widget_price"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="—"
                android:textSize="14sp"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/widget_change"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingStart="3dp"
                android:paddingEnd="3dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp" />

            <TextView
                android:id="@+id/widget_settings_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙"
                android:textSize="20sp"
                android:textColor="#8888AA"
                android:paddingStart="10dp"
                android:paddingEnd="0dp" />

        </LinearLayout>

        <!-- Net worth label -->
        <TextView
            android:id="@+id/widget_net_worth_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NET WORTH"
            android:textSize="8sp"
            android:textColor="#8888AA"
            android:textStyle="bold"
            android:layout_marginTop="6dp" />

        <!-- Net worth value -->
        <TextView
            android:id="@+id/widget_net_worth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:layout_marginTop="1dp" />

        <!-- DCA P/L row — hidden until data is available -->
        <LinearLayout
            android:id="@+id/widget_pnl_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="3dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="P/L"
                android:textSize="8sp"
                android:textColor="#8888AA"
                android:textStyle="bold"
                android:layout_marginEnd="5dp" />

            <TextView
                android:id="@+id/widget_pnl_amount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textSize="11sp"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/widget_pnl_pct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="10sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Network fee row — hidden until fee data is available and enabled -->
        <LinearLayout
            android:id="@+id/widget_fee_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="3dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡"
                android:textSize="8sp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/widget_fast_fee"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textSize="9sp"
                android:textColor="#F7931A" />

        </LinearLayout>

        <!-- Spacer — pushes timestamp to the bottom of the widget -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="" />

        <!-- Timestamp sits at the bottom, below the sparkline area -->
        <TextView
            android:id="@+id/widget_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="8sp"
            android:textColor="#555570" />

    </LinearLayout>

</FrameLayout>
