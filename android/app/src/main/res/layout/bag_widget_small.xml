<?xml version="1.0" encoding="utf-8"?>
<!-- Small (2×1): flat single-row net worth display -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:background="@drawable/widget_background">

    <TextView
        android:id="@+id/widget_net_worth_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NET WORTH"
        android:textSize="9sp"
        android:textColor="#8888AA"
        android:textStyle="bold"
        android:layout_marginEnd="10dp" />

    <TextView
        android:id="@+id/widget_net_worth"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="—"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_updated"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="9sp"
        android:textColor="#444460"
        android:maxLines="1"
        android:ellipsize="none"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widget_settings_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚙"
        android:textSize="20sp"
        android:textColor="#8888AA"
        android:paddingStart="10dp"
        android:paddingEnd="0dp" />

</LinearLayout>
