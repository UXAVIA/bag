<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ splash icon: 288dp as required by the splash screen spec.
     Solid black fill — invisible against the black splash background.
     Non-empty drawable prevents Android falling back to the launcher icon. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="288dp"
    android:height="288dp"
    android:viewportWidth="288"
    android:viewportHeight="288">
    <path
        android:fillColor="#000000"
        android:pathData="M0,0L288,0L288,288L0,288Z"/>
</vector>
